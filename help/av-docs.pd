#N canvas 400 200 360 230 16;
#N canvas 760 200 580 420 metadata 0;
#X msg 40 40 print;
#X text 100 40 general track info;
#X text 100 70 file path;
#X text 130 100 total tracks in playlist;
#X msg 50 70 path;
#X text 270 250 custom track info;
#X msg 60 100 tracks;
#X text 210 130 get metadata from last outlet;
#X msg 70 130 album;
#X msg 140 130 artist;
#X msg 150 280 print %artist% - %title% (%album%);
#X msg 150 310 print from %album%\\\, released %date%;
#N canvas 970 230 450 300 specs 0;
#X obj 30 170 outlet;
#X msg 30 60 print Bit Rate: %bitrate:\ 8% kb/s;
#X msg 40 90 print Sample Rate: %samplerate:\ 8% Hz;
#X msg 160 120 codec;
#X msg 50 120 samplefmt;
#X connect 1 0 0 0;
#X connect 2 0 0 0;
#X connect 3 0 0 0;
#X connect 4 0 0 0;
#X restore 140 210 pd specs;
#X obj 40 340 s \$1msg;
#X msg 140 170 dump;
#X text 190 170 print all metadata;
#X connect 0 0 13 0;
#X connect 4 0 13 0;
#X connect 6 0 13 0;
#X connect 8 0 13 0;
#X connect 9 0 13 0;
#X connect 10 0 13 0;
#X connect 11 0 13 0;
#X connect 12 0 13 0;
#X connect 14 0 13 0;
#X restore 100 60 pd metadata;
#N canvas 760 200 360 190 seeking 0;
#X obj 100 80 f;
#X msg 100 110 seek \$1;
#X obj 100 40 bng 24 250 50 0 empty empty empty 0 -12 0 16 #ff8300 #ff0400 #7c7c7c;
#X obj 100 140 s \$1msg;
#X obj 150 50 * 1000;
#X obj 150 20 radix 10 6 0 3 _ _ 0 0 _ _ _ 0;
#X connect 0 0 1 0;
#X connect 1 0 3 0;
#X connect 2 0 0 0;
#X connect 4 0 0 1;
#X connect 5 0 4 0;
#X restore 100 90 pd seeking;
#N canvas 760 200 430 450 channel-layout 0;
#X text 30 20 Channel layout is a 64-bit integer with a bit set for every channel (1 << channel)., f 34;
#X text 30 90 To make use of all channels \, use a prefix like 0x. Pd will interpret this as a symbol \, which can then be parsed., f 34;
#X text 30 180 0 = Front Left;
#X text 30 200 1 = Front Right;
#X text 30 220 2 = Front Center;
#X text 30 240 3 = Low Frequency;
#X text 30 260 4 = Back Left;
#X text 30 280 5 = Back Right;
#X text 30 300 6 = Front Left-of-Center;
#X text 30 320 7 = Front Right-of-Center;
#X text 30 340 8 = Back Center;
#X text 30 360 9 = Side Left;
#X text 30 380 10 = Side Right;
#X text 30 400 11 = Top Center;
#X text 30 420 12 = Top Front Left;
#X text 30 440 13 = Top Front Center;
#X text 30 460 14 = Top Front Right;
#X text 30 480 15 = Top Back Left;
#X text 30 500 16 = Top Back Center;
#X text 30 520 17 = Top Back Right;
#X text 30 540 29 = Stereo Left (Stereo down-mix);
#X text 30 560 30 = Stereo Right (Stereo down-mix);
#X text 30 580 31 = Wide Left;
#X text 30 600 32 = Wide Right;
#X text 30 620 33 = Surround Direct Left;
#X text 30 640 34 = Surround Direct Right;
#X text 30 660 35 = Low Frequency 2;
#X text 30 680 36 = Top Side Left;
#X text 30 700 37 = Top Side Right;
#X text 30 720 38 = Bottom Front Center;
#X text 30 740 39 = Bottom Front Left;
#X text 30 760 40 = Bottom Front Right;
#X text 30 780 41 = Side Surround Left;
#X text 30 800 42 = Side Surround Right;
#X text 30 820 43 = Top Surround Left;
#X text 30 840 44 = Top Surround Right;
#X text 30 860 61 = Binaural Left;
#X text 30 880 62 = Binaural Right;
#X restore 100 30 pd channel-layout;
#N canvas 760 200 360 270 streams 0;
#X obj 50 120 cupqb;
#X obj 170 120 cupqb;
#X msg 170 180 subtitle \$1;
#X msg 50 180 audio \$1;
#X text 30 10 Some file formats allow for multiple streams of the same media type \, such as language dubs for movies., f 29;
#X obj 50 210 s \$1msg;
#X obj 170 210 s \$1msg;
#X connect 0 0 3 0;
#X connect 1 0 2 0;
#X connect 2 0 6 0;
#X connect 3 0 5 0;
#X restore 100 120 pd streams;
#N canvas 760 200 660 130 url-test 0;
#X msg 30 20 open https://upload.wikimedia.org/wikipedia/en/1/10/Michael_Jackson_Thriller.ogg;
#X obj 30 90 s \$1msg;
#X text 120 90 not very stable. use at your own risk;
#X connect 0 0 1 0;
#X restore 100 150 pd url-test;
#N canvas 760 200 370 200 playlist 0;
#X obj 90 90 openpanel;
#X obj 90 30 bng 24 250 50 0 empty empty previous_directory 28 12 0 16 #ff8300 #ff0400 #7c7c7c;
#X msg 100 60 symbol ~/Music;
#X msg 90 120 append \$1;
#X obj 90 150 s \$1msg;
#X connect 0 0 3 0;
#X connect 1 0 0 0;
#X connect 2 0 0 0;
#X connect 3 0 4 0;
#X restore 100 180 pd playlist;
