# A command has ! as its first non-whitespace character.
# `!include` inherits the top-level metadata of the trax file specified.
# If `a.trax` was the file originally opened, this line gets ignored.
!include @../a.trax

disc =1

@baz
@../fizz

# skipped, reading a parent playlist would cause an infinite recursion
@../a.trax

# skipped, the current playlist is considered a parent playlist
@b.trax

# skipped, doesn't exist
@d.trax

# a playlist stops being a parent upon completion,
# which allows for multiple read-throughs
@c.trax
@c.trax